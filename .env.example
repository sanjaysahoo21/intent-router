# =============================================================
# Intent Router - Environment Variables
# =============================================================
# Copy this file to .env and fill in your API key.
#
# This application uses an OpenAI-compatible API endpoint.
# You can use any provider that supports the OpenAI chat format:
#   - Groq (free): https://console.groq.com
#   - OpenAI: https://platform.openai.com
#   - Google Gemini (via OpenAI compat): https://aistudio.google.com
#
# Example with Groq (recommended for free tier):
#   GROQ_API_KEY=gsk_your_groq_api_key_here
#
# Example with OpenAI:
#   OPENAI_API_KEY=sk-your_openai_api_key_here
# =============================================================

GROQ_API_KEY=your_groq_api_key_here
